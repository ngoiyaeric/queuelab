# Backend Service URLs
# Local Docker Compose: Use service names (backend)
# Render: Use Render-assigned internal or public hostnames
BACKEND_URL=http://backend:8000
WS_URL=ws://backend:8000

# Clerk (Existing)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe (Existing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET= # Required for payments endpoint in backend/app/api/payments.py
STRIPE_API_VERSION=2024-06-20

# Backend Configuration
OPENAI_API_KEY= # Required for agent service in backend/app/core/config.py
MODEL_NAME=gpt-4o
ELEVENLABS_API_KEY= # Required for voice service
ELEVENLABS_VOICE_ID=Lcf7WDeYIm7p8caqbe0O

# Frontend Specific
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Used for Stripe redirect URLs
