# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project credentials
# These variables are exposed to the client (NEXT_PUBLIC_ prefix is required)

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key

# GitHub Configuration (for deployment)
# GITHUB_TOKEN is automatically provided by GitHub Actions
# For manual deployments, create a Personal Access Token (PAT) with repo and workflow scopes
